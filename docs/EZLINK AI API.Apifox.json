                    "oasExtensions": ""
                  }
                ],
                "responseExamples": [],
                "requestBody": {
                  "type": "application/json",
                  "parameters": [],
                  "jsonSchema": {
                    "$ref": "#/definitions/184020027"
                  },
                  "required": false,
                  "mediaType": "application/json",
                  "examples": [
                    {
                      "name": "Veo文生视频示例",
                      "value": "{\n    \"model\": \"veo-3.1-generate-preview\",\n    \"instances\": [\n        {\n            \"prompt\": \"A cat playing piano in the rain, cinematic, 4K\"\n        }\n    ],\n    \"parameters\": {\n        \"aspectRatio\": \"16:9\",\n        \"durationSeconds\": 8,\n        \"generateAudio\": true,\n        \"negativePrompt\": \"blurry, low quality\",\n        \"personGeneration\": \"allow_adult\",\n        \"sampleCount\": 1\n    }\n}",
                      "oasKey": "veo3_text_to_video",
                      "oasExtensions": "",
                      "mediaType": "application/json"
                    },
                    {
                      "name": "Veo图生视频示例",
                      "value": "{\n    \"model\": \"veo-3.1-fast-generate-preview\",\n    \"instances\": [\n        {\n            \"prompt\": \"Beautiful sunset over the ocean with gentle waves, cinematic camera movement\",\n            \"image\": {\n                \"bytesBase64Encoded\": \"iVBORw0KGgoAAAANSUhEUgAA...\",\n                \"mimeType\": \"image/png\"\n            }\n        }\n    ],\n    \"parameters\": {\n        \"aspectRatio\": \"16:9\",\n        \"durationSeconds\": 8,\n        \"generateAudio\": true,\n        \"resizeMode\": \"pad\",\n        \"sampleCount\": 1\n    }\n}",
                      "oasKey": "veo3_image_to_video",
                      "oasExtensions": "",
                      "mediaType": "application/json"
                    },
                    {
                      "name": "Veo首帧+末帧控制示例",
                      "value": "{\n    \"model\": \"veo-3.1-generate-preview\",\n    \"instances\": [\n        {\n            \"prompt\": \"小狗在草地上奔跑，叼起了一张海报\",\n            \"image\": {\n                \"bytesBase64Encoded\": \"/9j/4AAQSkZJRg...\",\n                \"mimeType\": \"image/jpeg\"\n            },\n            \"lastFrame\": {\n                \"bytesBase64Encoded\": \"iVBORw0KGgo...\",\n                \"mimeType\": \"image/png\"\n            }\n        }\n    ],\n    \"parameters\": {\n        \"aspectRatio\": \"16:9\",\n        \"durationSeconds\": 8,\n        \"generateAudio\": true\n    }\n}",
                      "oasKey": "veo3_lastframe_example",
                      "oasExtensions": "",
                      "mediaType": "application/json"
                    },
                    {
                      "name": "Veo素材参考图示例",
                      "value": "{\n    \"model\": \"veo-3.1-generate-preview\",\n    \"instances\": [\n        {\n            \"prompt\": \"一个人在海边漫步，夕阳西下\",\n            \"referenceImages\": [\n                {\n                    \"image\": {\n                        \"bytesBase64Encoded\": \"/9j/4AAQSkZJRg...\",\n                        \"mimeType\": \"image/jpeg\"\n                    },\n                    \"referenceType\": \"asset\"\n                }\n            ]\n        }\n    ],\n    \"parameters\": {\n        \"aspectRatio\": \"16:9\",\n        \"durationSeconds\": 8,\n        \"generateAudio\": true\n    }\n}",
                      "oasKey": "veo3_reference_example",
                      "oasExtensions": "",
                      "mediaType": "application/json"
                    }
                  ],
                  "oasExtensions": ""
                },
                "description": "使用 Google Veo 系列模型进行视频生成。请求体与 Vertex AI 官方 API 保持一致（透传），仅需额外添加 model 字段用于路由。\n\n## 支持的模型\n\n- **Veo 2：** `veo-2.0-generate-001`\n- **Veo 3.0：** `veo-3.0-generate-001`、`veo-3.0-fast-generate-001`、`veo-3.0-generate-preview`、`veo-3.0-fast-generate-preview`\n- **Veo 3.1：** `veo-3.1-generate-preview`、`veo-3.1-fast-generate-preview`、`veo-3.1-generate-001`、`veo-3.1-fast-generate-001`\n\n## 请求体格式\n\n使用 `instances` 和 `parameters` 格式（与 Vertex AI 官方一致）：\n- **model**：模型 ID\n- **instances**：实例数组，包含 prompt 和可选的 image、lastFrame、video、mask、referenceImages\n- **parameters**：生成参数\n\n> 注意：本 API 仅支持 bytesBase64Encoded 方式传递媒体数据，不支持 gcsUri。\n\n## 功能支持\n\n| 功能 | Veo 2 | Veo 3.0 | Veo 3.1 |\n|------|-------|---------|--------|\n| 文生视频 (prompt) | ✅ | ✅ | ✅ |\n| 图生视频 (image) | ✅ | ✅ | ✅ |\n| 末帧控制 (lastFrame) | ✅ veo-2.0-generate-001 | ❌ | ✅ |\n| 视频延长 (video) | ✅ veo-2.0-generate-001 | ❌ | ❌ |\n| 遮罩编辑 (mask) | ✅ veo-2.0-generate-preview | ❌ | ❌ |\n| 素材参考图 (referenceImages) | ✅ veo-2.0-generate-exp | ❌ | ✅ veo-3.1-generate-preview |\n\n## 媒体对象格式\n\nimage / lastFrame / video 等字段使用扁平的 `bytesBase64Encoded` + `mimeType` 结构（不支持 gcsUri）：\n```json\n{\"bytesBase64Encoded\": \"BASE64...\", \"mimeType\": \"image/jpeg\"}\n```\n\n⚠️ **不要**使用 Gemini API 的 `inlineData` 嵌套格式，否则会报 `image is empty` 错误。\n\n## 参数说明\n\n- **durationSeconds**（必填）：Veo 2 支持 5-8 秒，Veo 3/3.1 支持 4、6、8 秒\n- **generateAudio**：Veo 3/3.1 必填\n- **enhancePrompt**：仅 Veo 2 支持\n- **resizeMode**：仅 Veo 3 系列图生视频时可用，可选 pad（默认）或 crop\n- **resolution**：仅 Veo 3/3.1 支持，可选 720p（默认）或 1080p\n- **personGeneration**：可选 allow_adult（默认）或 dont_allow\n- **sampleCount**：生成数量 1-4\n- **seed**：随机种子（0-4294967295）",
                "tags": [
                  "视频生成"
                ],
                "status": "released",
                "serverId": "",
                "operationId": "generateVideoVeo",
                "sourceUrl": "",
                "ordering": 0,
